# OpenRouter API key — routes to Claude, GPT, o3, DeepSeek
OPENROUTER_API_KEY="your-openrouter-key"

# Google AI API key — for Gemini models (direct, not via OpenRouter)
GOOGLE_API_KEY="your-google-ai-key"

# Optional: API key to protect the /api/ask endpoint
# If set, agents must pass this as X-Api-Key header or Bearer token
COUNCIL_API_KEY=""

# Optional: override the default port (3000)
# PORT=3000
